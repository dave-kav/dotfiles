worktree() {
  # error if no argument is passed
  if [ -z "$1" ]; then
    echo "Please provide a name for the worktree"
    return 1
  fi

  git worktree add ../$1 -f
  cp .env ../$1
  cp .env.test ../$1
  cd ../$1
  npm install
}

killPort() {

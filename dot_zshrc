}

function bastion_psql {
	local public_key_file="${HOME}/.ssh/id_ed25519.pub"
	local remote_db_host=$1

	if [[ ! -a "${public_key_file}" ]]; then
		echo "Public key file not found"
		return
	fi

	if [[ ! -n "${remote_db_host}" ]]; then
		echo "Remote database host is required"
		return
	fi

	if [[ -n "$2" ]]; then
		local instance_id=$2
	else
		local instance_id=$(aws ssm get-inventory \
			--filters Key=AWS:InstanceInformation.InstanceStatus,Values=Active,Type=Equal \
			--query 'Entities[*].Id' \
			--output json | jq -r '.[0]')

		if [[ "${instance_id}" == "null" ]]; then
			echo "Failed to find Bastion Instance"
			return
		fi
	fi

	local public_key=$(cat "${public_key_file}" | tr -d '\n')
	local instances_cache="${HOME}/.cache/bastion_psql"

	mkdir -p "${instances_cache}"

	if [[ ! -a "${instances_cache}/${instance_id}" ]]; then
		aws ssm send-command \
			--instance-ids "${instance_id}" \
			--document-name "AWS-RunShellScript" \
			--comment "Uploading public key" \
			--parameters "commands=['echo \"${public_key}\" | sudo tee -a /home/ec2-user/.ssh/authorized_keys']"

		touch "${instances_cache}/${instance_id}"
	fi

	local pid_to_kill=$(lsof -t -i :5432)

	if [[ -n "${pid_to_kill}" ]]; then
		echo "stopping process using port 5432"
		kill -TERM "${pid_to_kill}"
	fi

	ssh "${instance_id}" -L "5432:${remote_db_host}:5432" -N
}


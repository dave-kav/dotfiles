# Auto-rename the current zellij tab to the git repo name (or dir name)
_zellij_rename_tab() {
  [[ -z "$ZELLIJ" ]] && return
  local name
  name=$(git rev-parse --show-toplevel 2>/dev/null)
  if [[ -n "$name" ]]; then
    name=$(basename "$name")
  else
    name=$(basename "$PWD")
  fi
  zellij action rename-tab "$name"
}
autoload -Uz add-zsh-hook
add-zsh-hook chpwd _zellij_rename_tab
_zellij_rename_tab  # run once on shell init to name the tab immediately

# Launch (or reattach to) a named zellij dev session: nvim + claude side by side
# Usage: dev           → session named after current directory
#        dev my-name   → session named explicitly
dev() {
    local name="${1:-$(basename "$PWD")}"
    zellij attach --create "$name"
}

# Fuzzy-pick and attach to an existing zellij session
